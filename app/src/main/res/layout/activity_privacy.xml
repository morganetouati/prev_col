<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/page_padding"
        android:gravity="center_horizontal">

        <!-- Language Button (Flag) -->
        <Button
            android:id="@+id/languageButton"
            android:layout_width="@dimen/language_button_size"
            android:layout_height="@dimen/language_button_size"
            android:layout_gravity="end"
            android:text="\uD83C\uDDEB\uD83C\uDDF7"
            android:textSize="@dimen/text_title"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/desc_language_button"
            android:importantForAccessibility="yes" />

        <!-- Logo avec cercle gradient + œil vectoriel -->
        <FrameLayout
            android:layout_width="@dimen/big_icon_size"
            android:layout_height="@dimen/big_icon_size"
            android:layout_marginTop="@dimen/margin_16"
            android:layout_marginBottom="@dimen/page_padding">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_button" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_eye_logo"
                android:scaleType="centerInside"
                android:padding="12dp"
                android:contentDescription="@string/desc_app_logo"
                android:importantForAccessibility="yes" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/privacy_title"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="@dimen/margin_small"
            android:letterSpacing="0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/privacy_subtitle"
            android:textSize="@dimen/text_subtitle"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="@dimen/margin_xxxlarge" />

        <!-- Bloc confidentialité -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/padding_main"
            android:layout_marginBottom="@dimen/margin_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_medium">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDD12"
                    android:textSize="20sp"
                    android:layout_marginEnd="@dimen/margin_tiny" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_section_title"
                    android:textSize="@dimen/text_privacy_section"
                    android:textStyle="bold"
                    android:textColor="@color/accent" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/privacy_guarantees"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="@dimen/line_spacing_medium" />

        </LinearLayout>

        <!-- Bloc permissions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/padding_main"
            android:layout_marginBottom="@dimen/margin_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_medium">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\uD83D\uDCF1"
                    android:textSize="20sp"
                    android:layout_marginEnd="@dimen/margin_tiny" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/permissions_title"
                    android:textSize="@dimen/text_privacy_section"
                    android:textStyle="bold"
                    android:textColor="@color/accent_purple" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/permissions_list"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="@dimen/line_spacing_medium" />

        </LinearLayout>

        <!-- Bloc accessibilité -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="@dimen/padding_main"
            android:layout_marginBottom="@dimen/margin_xxlarge">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/margin_medium">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\u267F"
                    android:textSize="20sp"
                    android:layout_marginEnd="@dimen/margin_tiny" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/accessibility_title"
                    android:textSize="@dimen/text_privacy_section"
                    android:textStyle="bold"
                    android:textColor="@color/safe_green" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/accessibility_text"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="@dimen/line_spacing_medium" />

        </LinearLayout>

        <!-- Bouton accepter avec gradient -->
        <Button
            android:id="@+id/acceptPrivacyButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:text="@string/accept_button"
            android:textSize="@dimen/text_button"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_button_primary"
            android:elevation="@dimen/elevation_card"
            android:letterSpacing="0.05"
            android:layout_marginBottom="@dimen/margin_16"
            android:contentDescription="@string/desc_accept_button"
            android:importantForAccessibility="yes" />

        <TextView
            android:id="@+id/policyLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/privacy_policy_link"
            android:textSize="@dimen/text_hint"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="@dimen/margin_xxxlarge" />

    </LinearLayout>

</ScrollView>
